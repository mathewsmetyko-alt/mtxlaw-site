<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>MTX Law</title>
  <meta name="description" content="MTX Law website coming soon.">
  <style>
    :root {
      --bg: #f4f1ea;
      --card: #ffffff;
      --text: #1e1e1e;
      --muted: #66625d;
      --accent: #8c6b3f;
      --border: #ddd6ca;
      --shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      font-family: Georgia, "Times New Roman", Times, serif;
      color: var(--text);
      background:
        linear-gradient(rgba(244, 241, 234, 0.94), rgba(244, 241, 234, 0.94)),
        radial-gradient(circle at top left, #efe7d8, transparent 45%);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 32px 20px;
    }

    .card {
      width: 100%;
      max-width: 820px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 56px 48px;
      text-align: center;
    }

    .eyebrow {
      margin: 0 0 18px 0;
      font-size: 12px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
    }

    h1 {
      margin: 0;
      font-size: clamp(38px, 6vw, 58px);
      font-weight: 700;
      letter-spacing: 0.04em;
      line-height: 1.1;
    }

    .divider {
      width: 72px;
      height: 2px;
      background: var(--accent);
      margin: 24px auto 28px;
      border: 0;
    }

    .lead {
      margin: 0 auto;
      max-width: 640px;
      font-size: 21px;
      line-height: 1.7;
      color: #2b2b2b;
    }

    .subtext {
      margin: 22px auto 0;
      max-width: 620px;
      font-size: 17px;
      line-height: 1.75;
      color: var(--muted);
    }

    .contact {
      margin-top: 34px;
      font-size: 17px;
      line-height: 1.7;
    }

    .contact a {
      color: var(--text);
      text-decoration: none;
      border-bottom: 1px solid rgba(30, 30, 30, 0.25);
      transition: border-color 0.2s ease, color 0.2s ease;
    }

    .contact a:hover {
      color: var(--accent);
      border-color: var(--accent);
    }

    .footer {
      margin-top: 34px;
      padding-top: 24px;
      border-top: 1px solid var(--border);
      font-size: 13px;
      line-height: 1.7;
      color: var(--muted);
    }

    @media (max-width: 640px) {
      .card {
        padding: 40px 24px;
      }

      .lead {
        font-size: 19px;
      }

      .subtext,
      .contact {
        font-size: 16px;
      }
    }
  </style>
</head>
<body>
  <main class="card">
    <p class="eyebrow">MTX Law</p>
    <h1>Website Coming Soon</h1>
    <div class="divider"></div>

    <p class="lead">
      MTX Law is preparing to launch its new website.
    </p>

    <p class="subtext">
      We appreciate your patience while our online presence is being developed.
      Please check back soon for additional information about the firm and its services.
    </p>

    <p class="contact">
      For inquiries, please contact
      <a href="mailto:info@mtxlaw.com">info@mtxlaw.com</a>
    </p>

    <div class="footer">
      Attorney advertising where applicable. Prior results do not guarantee a similar outcome.
    </div>
  </main>
</body>
</html>
